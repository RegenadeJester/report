# =============================================================================
# Market Orca Frontend — Environment Variables (Vite)
# Copy to .env and fill in real values. NEVER commit .env to git.
# =============================================================================

# API backend base URL (default: auto-detected from window.location)
VITE_API_BASE=http://localhost:4567

# API backend port override (used when VITE_API_BASE is not set)
VITE_API_PORT=4567
