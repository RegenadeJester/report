# =============================================================================
# Market Orca Frontend — .gitignore
# NEVER commit secrets, credentials, or environment files.
# =============================================================================

# ── Environment / Secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.key
*.cert
*.pem

# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.pnp.cjs
yarn.lock.old

# ── Build Output ─────────────────────────────────────────────────────────────
dist/
dist-ssr/
*.tsbuildinfo

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
frontend.log

# ── Editor / OS ──────────────────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
.idea/
*.sw?
.DS_Store
Thumbs.db

# ── Temp ─────────────────────────────────────────────────────────────────────
tmp/
temp/
.tmp/
*~
